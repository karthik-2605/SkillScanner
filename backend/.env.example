# Express API gateway
PORT=8000

# Flask ML service base URL
ML_SERVICE_URL=http://localhost:5001

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=skillscanner
DB_NAME=skillScanner

# Retrain the ML model when a job is added (needs Python + ml-service deps).
# Set to "false" to skip retraining (e.g. if you don't run the ML service).
RETRAIN_ON_ADD=true
PYTHON_BIN=python3
